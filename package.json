  "type": "commonjs",
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "localtunnel": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "screenshot-desktop": "^1.15.3",
    "sqlite3": "^6.0.1",
    "strip-ansi": "^6.0.1"
  }
