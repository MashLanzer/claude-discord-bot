{
  "name": "claude-discord-bot",
  "version": "1.0.0",
  "description": "Discord bot that connects to Claude Code CLI",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "dev": "node bot.js",
    "pm2:start": "pm2 start bot.js --name claude-bot",
    "pm2:stop": "pm2 stop claude-bot",
    "pm2:restart": "pm2 restart claude-bot",
    "pm2:logs": "pm2 logs claude-bot"
  },
  "engines": {
    "node": "24.13.0",
    "npm": "11.6.2"
  },
  "overrides": {
